{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://schema.gesslar.dev/chrome-manifest/v1/colors.json",
  "title": "Chrome Theme Manifest",
  "description": "JSON Schema for Chrome browser theme manifest.json files. Key lists are derived from chromium/src/chrome/browser/themes/browser_theme_pack.cc.",
  "type": "object",
  "required": [
    "manifest_version",
    "name",
    "version",
    "theme"
  ],
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string"
    },
    "manifest_version": {
      "type": "integer",
      "description": "Must be 3 for current Chrome themes.",
      "enum": [
        2,
        3
      ]
    },
    "name": {
      "type": "string",
      "description": "The name of the theme.",
      "maxLength": 75
    },
    "version": {
      "type": "string",
      "description": "One to four dot-separated integers identifying the version of this theme.",
      "pattern": "^\\d+(\\.\\d+){0,3}$"
    },
    "description": {
      "type": "string",
      "description": "A plain text description of the theme.",
      "maxLength": 132
    },
    "short_name": {
      "type": "string",
      "description": "A short version of the theme name.",
      "maxLength": 45
    },
    "author": {
      "type": "string",
      "description": "The author of the theme."
    },
    "theme": {
      "type": "object",
      "description": "The theme configuration object.",
      "additionalProperties": false,
      "properties": {
        "colors": {
          "type": "object",
          "description": "RGB color overrides for UI elements. Values are [r, g, b] integer tuples (0-255). The 'toolbar' key additionally accepts an optional alpha float as a fourth element.",
          "additionalProperties": false,
          "properties": {
            "frame": {
              "$ref": "#/definitions/color_rgb"
            },
            "frame_inactive": {
              "$ref": "#/definitions/color_rgb"
            },
            "frame_incognito": {
              "$ref": "#/definitions/color_rgb"
            },
            "frame_incognito_inactive": {
              "$ref": "#/definitions/color_rgb"
            },
            "background_tab": {
              "$ref": "#/definitions/color_rgb"
            },
            "background_tab_inactive": {
              "$ref": "#/definitions/color_rgb"
            },
            "background_tab_incognito": {
              "$ref": "#/definitions/color_rgb"
            },
            "background_tab_incognito_inactive": {
              "$ref": "#/definitions/color_rgb"
            },
            "bookmark_text": {
              "$ref": "#/definitions/color_rgb"
            },
            "button_background": {
              "$ref": "#/definitions/color_rgb"
            },
            "omnibox_background": {
              "$ref": "#/definitions/color_rgb"
            },
            "omnibox_text": {
              "$ref": "#/definitions/color_rgb"
            },
            "tab_background_text": {
              "$ref": "#/definitions/color_rgb"
            },
            "tab_background_text_inactive": {
              "$ref": "#/definitions/color_rgb"
            },
            "tab_background_text_incognito": {
              "$ref": "#/definitions/color_rgb"
            },
            "tab_background_text_incognito_inactive": {
              "$ref": "#/definitions/color_rgb"
            },
            "tab_text": {
              "$ref": "#/definitions/color_rgb"
            },
            "toolbar": {
              "$ref": "#/definitions/color_rgba"
            },
            "toolbar_button_icon": {
              "$ref": "#/definitions/color_rgb"
            },
            "toolbar_text": {
              "$ref": "#/definitions/color_rgb"
            },
            "ntp_background": {
              "$ref": "#/definitions/color_rgb"
            },
            "ntp_header": {
              "$ref": "#/definitions/color_rgb"
            },
            "ntp_link": {
              "$ref": "#/definitions/color_rgb"
            },
            "ntp_text": {
              "$ref": "#/definitions/color_rgb"
            }
          }
        },
        "images": {
          "type": "object",
          "description": "Paths to PNG image resources, relative to the extension root.",
          "additionalProperties": false,
          "properties": {
            "theme_frame": {
              "$ref": "#/definitions/image_path"
            },
            "theme_frame_inactive": {
              "$ref": "#/definitions/image_path"
            },
            "theme_frame_incognito": {
              "$ref": "#/definitions/image_path"
            },
            "theme_frame_incognito_inactive": {
              "$ref": "#/definitions/image_path"
            },
            "theme_toolbar": {
              "$ref": "#/definitions/image_path"
            },
            "theme_tab_background": {
              "$ref": "#/definitions/image_path"
            },
            "theme_tab_background_inactive": {
              "$ref": "#/definitions/image_path"
            },
            "theme_tab_background_incognito": {
              "$ref": "#/definitions/image_path"
            },
            "theme_tab_background_incognito_inactive": {
              "$ref": "#/definitions/image_path"
            },
            "theme_tab_background_v": {
              "$ref": "#/definitions/image_path"
            },
            "theme_ntp_background": {
              "$ref": "#/definitions/image_path"
            },
            "theme_frame_overlay": {
              "$ref": "#/definitions/image_path"
            },
            "theme_frame_overlay_inactive": {
              "$ref": "#/definitions/image_path"
            },
            "theme_button_background": {
              "$ref": "#/definitions/image_path"
            },
            "theme_ntp_attribution": {
              "$ref": "#/definitions/image_path"
            },
            "theme_window_control_background": {
              "$ref": "#/definitions/image_path"
            }
          }
        },
        "tints": {
          "type": "object",
          "description": "HSL tint overrides for UI elements. Values are [h, s, l] floats in range 0.0-1.0. Use -1.0 for any component to leave it unchanged.",
          "additionalProperties": false,
          "properties": {
            "buttons": {
              "$ref": "#/definitions/tint"
            },
            "frame": {
              "$ref": "#/definitions/tint"
            },
            "frame_inactive": {
              "$ref": "#/definitions/tint"
            },
            "frame_incognito": {
              "$ref": "#/definitions/tint"
            },
            "frame_incognito_inactive": {
              "$ref": "#/definitions/tint"
            },
            "background_tab": {
              "$ref": "#/definitions/tint"
            }
          }
        },
        "properties": {
          "type": "object",
          "description": "Display property overrides.",
          "additionalProperties": false,
          "properties": {
            "ntp_background_alignment": {
              "type": "string",
              "description": "Alignment of the theme_ntp_background image. Accepts single-axis keywords or space-separated combinations. Default is 'center'.",
              "enum": [
                "center",
                "top",
                "bottom",
                "left",
                "right",
                "top left",
                "top right",
                "bottom left",
                "bottom right",
                "left top",
                "left bottom",
                "right top",
                "right bottom"
              ]
            },
            "ntp_background_repeat": {
              "type": "string",
              "description": "Tiling behaviour of the theme_ntp_background image. Default is 'repeat'.",
              "enum": [
                "repeat",
                "no-repeat",
                "repeat-x",
                "repeat-y"
              ]
            },
            "ntp_logo_alternate": {
              "type": "integer",
              "description": "Controls the Google logo variant on the NTP. 0 = colourful logo, 1 = white logo. When using a colour-only theme, setting 1 lets Chrome auto-select based on background luminance.",
              "enum": [
                0,
                1
              ]
            }
          }
        }
      }
    }
  },
  "definitions": {
    "color_channel": {
      "type": "integer",
      "minimum": 0,
      "maximum": 255
    },
    "alpha_channel": {
      "type": "number",
      "minimum": 0.0,
      "maximum": 1.0
    },
    "color_rgb": {
      "type": "array",
      "description": "An RGB colour as [r, g, b] integers in range 0-255.",
      "items": [
        {
          "$ref": "#/definitions/color_channel"
        },
        {
          "$ref": "#/definitions/color_channel"
        },
        {
          "$ref": "#/definitions/color_channel"
        }
      ],
      "additionalItems": false,
      "minItems": 3,
      "maxItems": 3
    },
    "color_rgba": {
      "type": "array",
      "description": "An RGBA colour as [r, g, b] integers in range 0-255, with an optional alpha float in range 0.0-1.0.",
      "items": [
        {
          "$ref": "#/definitions/color_channel"
        },
        {
          "$ref": "#/definitions/color_channel"
        },
        {
          "$ref": "#/definitions/color_channel"
        },
        {
          "$ref": "#/definitions/alpha_channel"
        }
      ],
      "additionalItems": false,
      "minItems": 3,
      "maxItems": 4
    },
    "tint_component": {
      "oneOf": [
        {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0
        },
        {
          "type": "number",
          "const": -1.0,
          "description": "Use -1.0 to leave this HSL component unchanged."
        }
      ]
    },
    "tint": {
      "type": "array",
      "description": "An HSL tint as [h, s, l] floats. Each component is 0.0-1.0, or -1.0 for no change. Hue is absolute (0/1 = red). Saturation and Lightness are relative to the source image: 0.5 = no change.",
      "items": [
        {
          "$ref": "#/definitions/tint_component"
        },
        {
          "$ref": "#/definitions/tint_component"
        },
        {
          "$ref": "#/definitions/tint_component"
        }
      ],
      "additionalItems": false,
      "minItems": 3,
      "maxItems": 3
    },
    "image_path": {
      "type": "string",
      "description": "A relative path to a PNG image file within the extension.",
      "pattern": ".*\\.png$"
    }
  }
}
