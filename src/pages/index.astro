---
import { readFileSync, readdirSync, existsSync } from 'node:fs'
import { join, basename } from 'node:path'

const schemasRoot = join(process.cwd(), 'public/schemas')
const schemaStrings = []

if(existsSync(schemasRoot)) {
  for(const category of readdirSync(schemasRoot, {withFileTypes: true}).filter(d => d.isDirectory())) {
    const catPath = join(schemasRoot, category.name)
    for(const version of readdirSync(catPath, {withFileTypes: true}).filter(d => d.isDirectory())) {
      const vPath = join(catPath, version.name)
      if(!existsSync(vPath)) continue
      for(const file of readdirSync(vPath).filter(f => f.endsWith('.json'))) {
        try {
          const data = JSON.parse(readFileSync(join(vPath, file), 'utf8'))
          schemaStrings.push({id: basename(file, '.json'), text: JSON.stringify(data, null, 2)})
        } catch { /* skip invalid */ }
      }
    }
  }
}

const cards = [
  {
    title: 'BeDoc',
    description: 'JSON schemas for bedoc action definitions',
    href: '/bedoc/',
    icon: 'codicon-file-code',
  },
  {
    title: 'Muddler',
    description: 'JSON schemas for Muddler project configuration',
    href: '/muddler/',
    icon: 'codicon-settings-gear',
  },
  {
    title: 'mpackage',
    description: 'XSD schemas for Mudlet .mpackage files',
    href: '/mudlet-mpackage/',
    icon: 'codicon-package',
  },
]
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>schema.gesslar.dev</title>
    <meta name="description" content="schema.gesslar.dev — schema hosting and reference" />
    <link rel="icon" type="image/x-icon" href="/img/favicon.ico" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@vscode/codicons@0.0.36/dist/codicon.css" />
    <style is:inline>
      * { margin: 0; padding: 0; box-sizing: border-box; }
      body { font-family: ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif; }

      .page {
        position: relative;
        min-height: 100vh;
        overflow: hidden;
        background:
          radial-gradient(circle at 10% 15%, rgba(71, 204, 177, 0.1), transparent 35%),
          radial-gradient(circle at 85% 10%, rgba(0, 146, 255, 0.12), transparent 30%),
          linear-gradient(140deg, #010a0a, #020f13 45%, #041a1f);
        color: #d9fff0;
        padding: 2.5rem 1.5rem;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: flex-start;
        padding-top: 12vh;
        gap: 1.5rem;
        isolation: isolate;
      }

      .matrix-layer {
        position: absolute;
        inset: 0;
        pointer-events: none;
        overflow: hidden;
        z-index: 0;
      }

      .block {
        position: absolute;
        color: #9ef4dc;
        will-change: opacity, transform;
        animation: fadeGlitch 10s infinite ease-in-out;
        animation-fill-mode: backwards;
        opacity: 0;
        line-height: 1.4;
        pointer-events: none;
        max-width: clamp(200px, 40vw, 500px);
        overflow: hidden;
      }

      .code {
        font-family: 'JetBrains Mono', 'IBM Plex Mono', 'Fira Code', monospace;
        white-space: pre;
        font-size: 12px;
        letter-spacing: 0.3px;
        opacity: 0.9;
      }

      .hero {
        position: relative;
        z-index: 1;
        text-align: center;
        width: min(960px, 100%);
        padding: 1rem 1rem 0.5rem;
      }

      .title-stack {
        position: relative;
        display: inline-block;
        filter: drop-shadow(0 0 26px rgba(126, 245, 197, 0.15));
      }

      .title {
        font-size: clamp(2.8rem, 5vw + 1rem, 4.6rem);
        margin: 0;
        line-height: 1.02;
        color: #dffcf0;
        text-shadow:
          0 0 12px rgba(126, 245, 197, 0.45),
          0 0 36px rgba(60, 177, 139, 0.45);
        position: relative;
        display: inline-block;
        animation: pulseGlow 5s ease-in-out infinite;
      }

      .title::after {
        content: attr(data-text);
        position: absolute;
        inset: 0;
        color: #9bf0d0;
        opacity: 0.18;
        mix-blend-mode: color-burn;
        text-shadow:
          1px 0 12px rgba(86, 255, 191, 0.35),
          -1px 0 12px rgba(120, 197, 255, 0.25);
        pointer-events: none;
        animation: jitterGhost 10s infinite ease-in-out;
        will-change: opacity, transform;
      }

      .about {
        position: relative;
        z-index: 1;
        max-width: 800px;
        width: 100%;
        padding: 1.25rem 1.5rem;
        background: linear-gradient(135deg, rgba(6, 26, 26, 0.4), rgba(4, 18, 22, 0.5));
        outline: 1px solid rgba(126, 245, 197, 0.12);
        border-radius: 16px;
        backdrop-filter: blur(10px);
        box-shadow:
          0 20px 60px rgba(0, 0, 0, 0.5),
          0 0 0 1px rgba(126, 245, 197, 0.08) inset;
      }

      .about h3 {
        margin: 0 0 0.5rem;
        color: #dffcf0;
        text-shadow: 0 0 8px rgba(126, 245, 197, 0.3);
      }

      .about > p {
        margin: 0;
        font-size: 1.1rem;
        line-height: 1.7;
        color: #b9e8d6;
        opacity: 0.9;
      }

      .features {
        display: grid;
        gap: 1rem;
        grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
        margin-top: 1.25rem;
      }

      .feature {
        display: flex;
        gap: 0.5rem;
        align-items: flex-start;
        padding: 0.5rem;
        background: rgba(126, 245, 197, 0.03);
        border: 1px solid rgba(126, 245, 197, 0.08);
        border-radius: 8px;
      }

      .feature-icon {
        font-size: 1.5rem;
        line-height: 1;
        flex-shrink: 0;
      }

      .feature h4 { margin: 0 0 0.25rem; color: #cff7e8; font-size: 1rem; }
      .feature p { margin: 0; font-size: 0.9rem; line-height: 1.15; color: #9bd7c1; opacity: 0.85; }

      .cards {
        position: relative;
        z-index: 1;
        max-width: 800px;
        width: 100%;
        display: grid;
        gap: 1rem;
        grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
      }

      .card {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
        padding: 1.25rem;
        background: linear-gradient(135deg, rgba(6, 26, 26, 0.5), rgba(4, 18, 22, 0.6));
        outline: 1px solid rgba(126, 245, 197, 0.12);
        border-radius: 12px;
        backdrop-filter: blur(10px);
        box-shadow:
          0 10px 40px rgba(0, 0, 0, 0.4),
          0 0 0 1px rgba(126, 245, 197, 0.06) inset;
        text-decoration: none;
        color: inherit;
        transition: outline-color 0.2s, box-shadow 0.2s, transform 0.2s;
      }

      .card:hover {
        outline-color: rgba(126, 245, 197, 0.35);
        box-shadow:
          0 10px 40px rgba(0, 0, 0, 0.4),
          0 0 20px rgba(126, 245, 197, 0.1),
          0 0 0 1px rgba(126, 245, 197, 0.15) inset;
        transform: translateY(-2px);
      }

      .card-header {
        display: flex;
        align-items: center;
        gap: 0.5rem;
      }

      .card-icon {
        font-size: 1.25rem;
        color: #2cbda2;
      }

      .card-title {
        font-size: 1.1rem;
        font-weight: 600;
        color: #dffcf0;
        margin: 0;
      }

      .card-description {
        font-size: 0.9rem;
        line-height: 1.4;
        color: #9bd7c1;
        opacity: 0.85;
        margin: 0;
        flex: 1;
      }

      .card-link {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        font-size: 0.9rem;
        font-weight: 500;
        color: #2cbda2;
        margin-top: 0.5rem;
        transition: gap 0.2s;
      }

      .card:hover .card-link {
        color: #6df7d5;
        gap: 0.65rem;
      }

      @keyframes fadeGlitch {
        0% { opacity: 0; }
        50% { opacity: 0.5; }
        100% { opacity: 0; transform: perspective(400px) translateZ(100px); filter: blur(5px); }
      }

      @keyframes jitterGhost {
        0% { transform: translate(0, 0); opacity: 0.18; }
        20% { transform: translate(-1px, 1px); opacity: 0.25; }
        40% { transform: translate(1px, -1px); opacity: 0.2; }
        60% { transform: translate(0px, 0.5px); opacity: 0.26; }
        80% { transform: translate(-0.5px, -0.5px); opacity: 0.17; }
        100% { transform: translate(0, 0); opacity: 0.22; }
      }

      @keyframes pulseGlow {
        0% { text-shadow: 0 0 12px rgba(126, 245, 197, 0.45), 0 0 36px rgba(60, 177, 139, 0.45); }
        50% { text-shadow: 0 0 18px rgba(126, 245, 197, 0.55), 0 0 46px rgba(60, 177, 139, 0.55); }
        100% { text-shadow: 0 0 12px rgba(126, 245, 197, 0.45), 0 0 36px rgba(60, 177, 139, 0.45); }
      }

      @media screen and (max-width: 996px) {
        .page { padding: 1.5rem; }
      }

      @media screen and (max-width: 640px) {
        .page { padding: 1rem; }
        .title { font-size: clamp(2rem, 3vw + 1rem, 3rem); }
        .about { padding: 1rem; }
        .about h3 { line-height: 1.1rem; font-size: 1.1rem; }
        .about > p { line-height: 1.2rem; font-size: 1rem; }
        .features { grid-template-columns: 1fr; gap: 0.75rem; }
        .cards { grid-template-columns: 1fr; }
      }
    </style>
  </head>
  <body>
    <main class="page">
      <div class="matrix-layer" aria-hidden="true" id="matrix"></div>

      <section class="hero">
        <div class="title-stack">
          <h1 class="title" data-text="schema.gesslar.dev">schema.gesslar.dev</h1>
        </div>
      </section>

      <section class="about">
        <h3>What are schemas?</h3>
        <p>
          Schemas define the structure and rules for your data formats. They provide validation,
          autocomplete, and inline documentation right in your editor — catching errors before
          you run your code.
        </p>

        <div class="features">
          <div class="feature">
            <i class="codicon codicon-check feature-icon"></i>
            <div>
              <h4>Validation</h4>
              <p>Catch errors as you type with real-time structure checking</p>
            </div>
          </div>
          <div class="feature">
            <i class="codicon codicon-sparkle feature-icon"></i>
            <div>
              <h4>Autocomplete</h4>
              <p>Smart suggestions for properties, values, and types</p>
            </div>
          </div>
          <div class="feature">
            <i class="codicon codicon-book feature-icon"></i>
            <div>
              <h4>Documentation</h4>
              <p>Inline help and examples without leaving your editor</p>
            </div>
          </div>
        </div>
      </section>

      <div class="cards">
        {cards.map(card => (
          <a class="card" href={card.href}>
            <div class="card-header">
              <i class={`codicon ${card.icon} card-icon`}></i>
              <h2 class="card-title">{card.title}</h2>
            </div>
            <p class="card-description">{card.description}</p>
            <span class="card-link">Explore schema <i class="codicon codicon-arrow-right" /></span>
          </a>
        ))}
      </div>
    </main>

    <script is:inline id="schema-data" type="application/json" set:html={JSON.stringify(schemaStrings)} />
    <script is:inline>
      const schemaStrings = JSON.parse(document.getElementById('schema-data').textContent)
      const BLOCK_COUNT = 3
      const ALL_POSITIONS = [
        {top: '8%', left: '5%'},
        {top: '15%', right: '8%'},
        {top: '35%', left: '3%'},
        {top: '42%', right: '12%'},
        {top: '58%', left: '10%'},
        {top: '65%', right: '6%'},
        {top: '78%', left: '7%'},
        {top: '85%', right: '10%'},
        {top: '25%', left: '50%'},
        {top: '72%', right: '45%'},
      ]

      const randomBetween = (min, max) => Math.random() * (max - min) + min

      const pickSnippet = () => {
        if(!schemaStrings.length) return '{ "schema": true }'
        const source = schemaStrings[Math.floor(Math.random() * schemaStrings.length)].text
        const lines = source.split('\n')
        const length = Math.max(5, Math.floor(randomBetween(6, 10)))
        const start = Math.floor(randomBetween(0, Math.max(lines.length - length, 1)))
        return lines.slice(start, start + length).join('\n')
      }

      const getUnusedPosition = (usedPositions) => {
        const available = ALL_POSITIONS.filter(pos =>
          !usedPositions.some(used => used.top === pos.top && used.left === pos.left && used.right === pos.right)
        )
        return available.length > 0
          ? available[Math.floor(Math.random() * available.length)]
          : ALL_POSITIONS[Math.floor(Math.random() * ALL_POSITIONS.length)]
      }

      const matrix = document.getElementById('matrix')
      const blocks = []

      for(let i = 0; i < BLOCK_COUNT; i++) {
        const pos = getUnusedPosition(blocks)
        const el = document.createElement('div')
        el.className = 'block'
        const code = document.createElement('div')
        code.className = 'code'
        code.textContent = pickSnippet()
        el.appendChild(code)
        el.style.top = pos.top
        if(pos.left) el.style.left = pos.left
        if(pos.right) el.style.right = pos.right
        el.style.animationDelay = i * 1.2 + 's'

        el.addEventListener('animationiteration', () => {
          const otherPositions = blocks.filter(b => b.el !== el).map(b => b.pos)
          const newPos = getUnusedPosition(otherPositions)
          el.style.top = newPos.top
          el.style.left = newPos.left || ''
          el.style.right = newPos.right || ''
          el.querySelector('.code').textContent = pickSnippet()
          const blockData = blocks.find(b => b.el === el)
          if(blockData) blockData.pos = newPos
        })

        matrix.appendChild(el)
        blocks.push({el, pos})
      }
    </script>
  </body>
</html>
